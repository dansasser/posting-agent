# .env.example
# Copy this file to .env and fill in your credentials.

# --- Facebook API Credentials ---
# Credentials for accessing the Facebook Graph API.
# You can get these from the Meta for Developers portal.
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_USER_ACCESS_TOKEN=your_user_access_token

# --- OpenAI API Key ---
# Your API key for the language model.
OPENAI_API_KEY=your_openai_api_key

# --- Scheduler Settings ---
# Comma-separated list of hours (0-23) to schedule posts.
POST_SCHEDULE_HOURS=9,12,15,18,21

# --- Application Settings ---
# Set to "DEBUG", "INFO", "WARNING", "ERROR"
LOG_LEVEL=INFO